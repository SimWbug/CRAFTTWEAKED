local W, H = term.getSize()

-- Session joueur
local SESSION = { logged_in = false, name = "", balance = 0 }

-- ── UTILITAIRES UI ───────────────────────────────────────────
local function cls()
    term.setBackgroundColor(colors.black)
    term.clear()
    term.setCursorPos(1,1)
end

local function at(x, y, text, fg, bg)
    term.setCursorPos(x, y)
    if bg then term.setBackgroundColor(bg) end
    if fg then term.setTextColor(fg) end
    term.write(text)
end

local function center(y, text, fg, bg)
    local x = math.floor((W - #text) / 2) + 1
    at(x, y, text, fg, bg)
end

local function hline(y, char, fg, bg)
    term.setCursorPos(1, y)
    if bg  then term.setBackgroundColor(bg) end
    if fg  then term.setTextColor(fg) end
    term.write(string.rep(char or "-", W))
end

-- Blit une ligne entiere (texte, fg_str, bg_str de longueur W)
local function blit_line(y, text, fg_str, bg_str)
    term.setCursorPos(1, y)
    term.blit(text, fg_str, bg_str)
end

-- ── DESSIN ROULETTE NFP-STYLE ────────────────────────────────
-- La roulette est dessinees avec term.blit sur 9 lignes
-- Chaque "frame" est une table de {texte, fg, bg} par ligne
-- Les couleurs blit: 0=black 1=red 2=green 3=yellow 4=blue
--   5=purple 6=cyan 7=white 8=gray 9=lightGray a=lightBlue
--   b=pink c=magenta d=orange e=lime f=brown

-- Genere les frames d'animation de la roulette
-- state: "rouge" | "noir" | "vert" | "spin"
local ROULETTE_Y = 3   -- ligne de depart de la roulette
local ROULETTE_H = 11  -- hauteur du dessin

-- Sequence de couleurs sur la roue (37 cases style euro)
-- R=rouge N=noir V=vert
local WHEEL = {
    "V","R","N","R","N","R","N","R","N","R","N",
    "R","N","R","N","R","N","R","N","R","N","R",
    "N","R","N","R","N","R","N","R","N","R","N",
    "R","N","R","N","R"
}

-- Convertit une couleur de case en char blit
local function case_to_blit(c)
    if c == "R" then return "e", "1" end  -- fg lime sur rouge
    if c == "N" then return "7", "8" end  -- fg white sur gray
    if c == "V" then return "7", "2" end  -- fg white sur green
    return "7", "8"
end

-- Dessine la roue avec un offset de spin
-- offset: index de depart dans WHEEL
local function draw_wheel(offset, highlight)
    local cx = math.floor(W / 2)

    -- Fond du cadre roulette
    term.setBackgroundColor(colors.gray)
    for y = ROULETTE_Y, ROULETTE_Y + ROULETTE_H - 1 do
        term.setCursorPos(1, y)
        term.write(string.rep(" ", W))
    end

    -- Titre cadre
    at(1, ROULETTE_Y, string.rep(" ", W), colors.yellow, colors.gray)
    center(ROULETTE_Y, " CGCasino - Roulette ", colors.yellow, colors.gray)

    -- La bande de cases de la roue (2 lignes de hauteur)
    -- On affiche 19 cases centrees sur la roue
    local visible = 19
    local start_x = math.floor((W - visible * 2) / 2) + 1

    for i = 1, visible do
        local wheel_idx = ((offset + i - 1) % #WHEEL) + 1
        local case = WHEEL[wheel_idx]
        local fg_b, bg_b = case_to_blit(case)

        -- Ligne haute de la case
        local x = start_x + (i-1) * 2
        if x > 0 and x <= W-1 then
            term.setCursorPos(x, ROULETTE_Y + 2)
            term.blit("  ", fg_b..fg_b, bg_b..bg_b)
            term.setCursorPos(x, ROULETTE_Y + 3)
            -- Affiche le numero sur 2 chars
            local num_str = string.format("%2d", wheel_idx)
            term.blit(num_str, fg_b..fg_b, bg_b..bg_b)
            term.setCursorPos(x, ROULETTE_Y + 4)
            term.blit("  ", fg_b..fg_b, bg_b..bg_b)
        end
    end

    -- Marqueur central (fleche vers le bas)
    local marker_x = math.floor(W / 2)
    at(marker_x, ROULETTE_Y + 1, "vv", colors.yellow, colors.gray)
    at(marker_x, ROULETTE_Y + 5, "^^", colors.yellow, colors.gray)

    -- Separateur bas du cadre
    at(1, ROULETTE_Y + 6, string.rep(" ", W), colors.yellow, colors.gray)

    -- Zone resultat
    if highlight then
        local res_col = colors.black
        local res_bg  = colors.gray
        local res_txt = ""
        if highlight == "R" then
            res_col = colors.white; res_bg = colors.red
            res_txt = "    ROUGE    "
        elseif highlight == "N" then
            res_col = colors.white; res_bg = colors.gray
            res_txt = "    NOIR     "
        elseif highlight == "V" then
            res_col = colors.white; res_bg = colors.green
            res_txt = "    VERT     "
        elseif highlight == "spin" then
            res_col = colors.yellow; res_bg = colors.gray
            res_txt = "   . . . .   "
        end
        center(ROULETTE_Y + 7, res_txt, res_col, res_bg)
        at(1, ROULETTE_Y + 7, " ", colors.gray, colors.gray)
        at(W, ROULETTE_Y + 7, " ", colors.gray, colors.gray)
    end
end

-- ── ANIMATION SPIN ───────────────────────────────────────────
-- Anime la roulette qui tourne, puis s'arrete sur result_idx
-- result: "R"|"N"|"V"
local function animate_spin(result)
    -- Trouver un index de la roue correspondant au resultat
    local target_indices = {}
    for i, c in ipairs(WHEEL) do
        if c == result then
            table.insert(target_indices, i)
        end
    end
    -- Choisir un index cible aleatoire parmi ceux du bon type
    local target = target_indices[math.random(#target_indices)]

    -- Calculer l'offset final: on veut que target soit au centre (case 10/19)
    local center_pos = 10
    local final_offset = (target - center_pos) % #WHEEL

    -- Animation: plusieurs tours rapides puis deceleration
    local total_frames = 45
    local offset = math.random(#WHEEL)

    for frame = 1, total_frames do
        -- Vitesse: rapide au debut, lent a la fin
        local progress = frame / total_frames
        local speed
        if progress < 0.5 then
            speed = 3
        elseif progress < 0.75 then
            speed = 2
        elseif progress < 0.9 then
            speed = 1
        else
            speed = 1
        end

        -- Derniere frame: position finale exacte
        if frame == total_frames then
            offset = final_offset
        else
            offset = (offset + speed) % #WHEEL
        end

        draw_wheel(offset, frame == total_frames and result or "spin")

        -- Delai variable (accelere puis ralentit)
        local delay
        if progress < 0.5 then
            delay = 0.04
        elseif progress < 0.75 then
            delay = 0.07
        elseif progress < 0.9 then
            delay = 0.12
        else
            delay = 0.18
        end
        os.sleep(delay)
    end
end

-- ── TIRER LA ROULETTE ────────────────────────────────────────
local function spin_roulette()
    local r = math.random(100)
    if r <= CFG.prob_rouge then
        return "R", CFG.mult_rouge
    elseif r <= CFG.prob_rouge + CFG.prob_noir then
        return "N", CFG.mult_noir
    else
        return "V", CFG.mult_vert
    end
end

-- ── INTERFACE PRINCIPALE ─────────────────────────────────────
local function draw_main_ui(message, msg_col)
    cls()

    -- Header
    hline(1, " ", colors.yellow, colors.orange)
    center(1, " CGCasino - Roulette ", colors.black, colors.orange)

    -- Roue par defaut
    draw_wheel(0, nil)

    -- Infos joueur (sous la roue)
    local info_y = ROULETTE_Y + ROULETTE_H - 1

    term.setBackgroundColor(colors.black)
    at(1, info_y, string.rep(" ", W), colors.black, colors.black)

    if SESSION.logged_in then
        at(2, info_y, "Joueur: ", colors.lightGray, colors.black)
        at(10, info_y, SESSION.name, colors.cyan, colors.black)
        at(W-18, info_y, "Solde: ", colors.lightGray, colors.black)
        at(W-11, info_y, string.format("%.4f CGC", SESSION.balance), colors.lime, colors.black)
    end

    -- Tableau des mises
    local bet_y = info_y + 1
    term.setBackgroundColor(colors.black)

    -- Rouge
    local rw = math.floor(W/3)
    at(1, bet_y,      string.rep(" ", rw), colors.white, colors.red)
    center(bet_y, "ROUGE x"..CFG.mult_rouge, colors.white, colors.red)

    -- Noir
    at(rw+1, bet_y,   string.rep(" ", rw), colors.white, colors.gray)
    local nx = rw + math.floor((rw - 8) / 2) + 1
    at(nx, bet_y, "NOIR x"..CFG.mult_noir, colors.white, colors.gray)

    -- Vert
    at(rw*2+1, bet_y, string.rep(" ", W - rw*2), colors.white, colors.green)
    local vx = rw*2 + math.floor((W - rw*2 - 9) / 2) + 1
    at(vx, bet_y, "VERT x"..CFG.mult_vert, colors.white, colors.green)

    -- Message
    local msg_y = bet_y + 1
    at(1, msg_y, string.rep(" ", W), colors.black, colors.black)
    if message then
        center(msg_y, message, msg_col or colors.white, colors.black)
    end

    -- Instructions
    local inst_y = H - 2
    at(1, inst_y, string.rep(" ", W), colors.black, colors.black)
    at(1, inst_y+1, string.rep(" ", W), colors.black, colors.black)

    if SESSION.logged_in then
        at(2, inst_y,   "[R] Rouge  [N] Noir  [V] Vert", colors.lightGray, colors.black)
        at(2, inst_y+1, "[Q] Quitter", colors.lightGray, colors.black)
    else
        at(2, inst_y,   "[C] Connexion  [I] Inscription  [Q] Quitter", colors.lightGray, colors.black)
    end
end

-- ── LOGIN ────────────────────────────────────────────────────
local function screen_login()
    cls()
    hline(1, " ", colors.yellow, colors.orange)
    center(1, " CGCasino - Connexion ", colors.black, colors.orange)

    at(2, 4, "Nom de compte  : ", colors.lightGray, colors.black)
    term.setTextColor(colors.cyan)
    local name = read()

    at(2, 6, "Mot de passe   : ", colors.lightGray, colors.black)
    term.setTextColor(colors.cyan)
    local pw = read("*")

    at(2, 8, "Connexion...", colors.lightGray, colors.black)

    local res = bank.send_raw and bank.send_raw({
        cmd = "login", account = name, password = pw
    })
    -- send_raw n'existe pas dans l'API publique, on utilise
    -- login via balance_auth
    -- On passe par une requete directe au modem
    local modem_r = peripheral.wrap(CFG.modem_side)
    modem_r.transmit(CFG.server_ch, CFG.my_ch, {
        cmd = "login", account = name, password = pw,
        reply_ch = CFG.my_ch
    })
    local timer = os.startTimer(5)
    local login_res = { ok = false, msg = "Timeout" }
    while true do
        local e, s, ch, rch, m = os.pullEvent()
        if e == "modem_message" and ch == CFG.my_ch and type(m) == "table" then
            os.cancelTimer(timer)
            login_res = m; break
        elseif e == "timer" and s == timer then break end
    end

    if login_res.ok then
        SESSION.logged_in = true
        SESSION.name      = name
        SESSION.balance   = login_res.balance or 0
        at(2, 8, "Connexion reussie ! Bienvenue, " .. name, colors.lime, colors.black)
        os.sleep(1.5)
    else
        at(2, 8, "ECHEC: " .. (login_res.msg or "?"), colors.red, colors.black)
        os.sleep(2)
    end
end

