    if pw1 ~= pw2 then
        at(2, 10, "Mots de passe differents !", colors.red, colors.black)
        os.sleep(2); return
    end
    if #pw1 < 4 then
        at(2, 10, "Mot de passe trop court (4 min).", colors.red, colors.black)
        os.sleep(2); return
    end

    local modem_r = peripheral.wrap(CFG.modem_side)
    modem_r.transmit(CFG.server_ch, CFG.my_ch, {
        cmd = "register", account = name, password = pw1,
        reply_ch = CFG.my_ch
    })
    local timer = os.startTimer(5)
    local reg_res = { ok = false, msg = "Timeout" }
    while true do
        local e, s, ch, rch, m = os.pullEvent()
        if e == "modem_message" and ch == CFG.my_ch and type(m) == "table" then
            os.cancelTimer(timer); reg_res = m; break
        elseif e == "timer" and s == timer then break end
    end

    if reg_res.ok then
        at(2, 10, "Compte cree ! Vous pouvez vous connecter.", colors.lime, colors.black)
    else
        at(2, 10, "ECHEC: " .. (reg_res.msg or "?"), colors.red, colors.black)
    end
    os.sleep(2)
end

-- ── MISE ─────────────────────────────────────────────────────
local function ask_bet(color_name, color_fg, color_bg)
    -- Petite fenetre de mise
    local bw, bh = 30, 7
    local bx = math.floor((W - bw) / 2) + 1
    local by = math.floor((H - bh) / 2) + 1

    -- Fond fenetre
    for y = by, by+bh-1 do
        at(bx, y, string.rep(" ", bw), colors.white, colors.gray)
    end
    -- Titre
    at(bx, by, string.rep(" ", bw), color_fg, color_bg)
    center(by, " Mise sur " .. color_name .. " ", color_fg, color_bg)

    at(bx+2, by+2, string.format("Solde: %.4f CGC", SESSION.balance), colors.lime, colors.gray)
    at(bx+2, by+3, string.format("Min: %.1f  Max: %.1f", CFG.bet_min, CFG.bet_max), colors.lightGray, colors.gray)
    at(bx+2, by+4, "Mise: ", colors.white, colors.gray)
    term.setCursorPos(bx+8, by+4)
    term.setTextColor(colors.yellow)
    term.setBackgroundColor(colors.gray)
    local input = read()
    local amount = tonumber(input)

    at(bx+2, by+5, string.rep(" ", bw-4), colors.white, colors.gray)

    if not amount then
        at(bx+2, by+5, "Annule.", colors.lightGray, colors.gray)
        os.sleep(1); return nil
    end
    if amount < CFG.bet_min or amount > CFG.bet_max then
        at(bx+2, by+5, string.format("Hors limites (%.1f-%.1f)", CFG.bet_min, CFG.bet_max), colors.red, colors.gray)
        os.sleep(2); return nil
    end
    if amount > SESSION.balance then
        at(bx+2, by+5, "Solde insuffisant !", colors.red, colors.gray)
        os.sleep(2); return nil
    end
    return amount
end

-- ── JOUER UN TOUR ────────────────────────────────────────────
local function play_round(choice)
    -- choice: "R"|"N"|"V"
    local color_names = { R = "ROUGE", N = "NOIR", V = "VERT" }
    local color_fgs   = { R = colors.white,  N = colors.white, V = colors.white }
    local color_bgs   = { R = colors.red,    N = colors.gray,  V = colors.green }
    local multipliers = { R = CFG.mult_rouge, N = CFG.mult_noir, V = CFG.mult_vert }

    local bet = ask_bet(color_names[choice], color_fgs[choice], color_bgs[choice])
    if not bet then return end

    -- Retirer la mise
    local ok, msg, new_bal = bank.withdraw(SESSION.name, bet, "Mise roulette " .. color_names[choice])
    if not ok then
        draw_main_ui("Erreur banque: " .. msg, colors.red)
        os.sleep(2); return
    end
    SESSION.balance = new_bal

    -- Tirer le resultat
    math.randomseed(os.time() + os.clock() * 1000)
    local result, mult = spin_roulette()

    -- Afficher l'UI de jeu + animation
    draw_main_ui("Mise: " .. string.format("%.4f", bet) .. " CGC | En cours...", colors.yellow)
    os.sleep(0.3)
    animate_spin(result)

    -- Calculer gain/perte
    local won = (result == choice)
    local result_msg
    local result_col

    if won then
        local gain = bet * multipliers[choice]
        local net  = gain - bet
        local ok2, _, new_bal2 = bank.deposit(SESSION.name, gain, "Gain roulette x" .. multipliers[choice])
        if ok2 then SESSION.balance = new_bal2 end

        result_msg = string.format("GAGNE ! +%.4f CGC (x%d)", net, multipliers[choice])
        result_col = colors.lime
    else
        result_msg = string.format("PERDU. -%.4f CGC", bet)
        result_col = colors.red
    end

    -- Afficher resultat final
    local res_y = ROULETTE_Y + 7
    at(1, res_y, string.rep(" ", W), colors.black, colors.black)
    center(res_y, result_msg, result_col, colors.black)

    -- Mettre a jour solde affiche
    at(W-18, ROULETTE_Y + ROULETTE_H - 1,
       string.format("Solde: %.4f CGC", SESSION.balance),
       SESSION.balance > 0 and colors.lime or colors.red,
       colors.black)

    os.sleep(3)
end

-- ── BOUCLE PRINCIPALE ────────────────────────────────────────

-- Reset graine aleatoire
math.randomseed(os.time())

-- Verifier connexion banque
setup_palette()
cls()
center(math.floor(H/2), "Connexion a CGBank...", colors.yellow, colors.black)
local ping_ok, ping_msg = bank.ping()
if not ping_ok then
    cls()
    center(math.floor(H/2) - 1, "CGBank hors ligne !", colors.red, colors.black)
    center(math.floor(H/2) + 1, ping_msg, colors.gray, colors.black)
    center(math.floor(H/2) + 3, "Verifiez le serveur et relancez.", colors.lightGray, colors.black)
    os.sleep(4)
    -- Restaure palette par defaut
    term.setTextColor(colors.white)
    term.setBackgroundColor(colors.black)
    term.clear()
    return
end
os.sleep(0.5)

local message     = "Connectez-vous pour jouer !"
local message_col = colors.yellow

while true do
    -- Rafraichir solde si connecte
    if SESSION.logged_in then
        local ok, bal = bank.balance(SESSION.name)
        if ok then SESSION.balance = bal end
    end

    draw_main_ui(message, message_col)
    message = nil

    local _, key = os.pullEvent("key")

    if key == keys.q then
        cls()
        center(math.floor(H/2), "A bientot au CGCasino !", colors.yellow, colors.black)
        os.sleep(1.5)
        -- Restaure palette
        term.setPaletteColor(colors.red,    0xFF0000)
        term.setPaletteColor(colors.green,  0x00FF00)
        term.setPaletteColor(colors.blue,   0x0000FF)
        term.setPaletteColor(colors.black,  0x000000)
        term.setPaletteColor(colors.white,  0xFFFFFF)
        term.setPaletteColor(colors.yellow, 0xFFFF00)
        term.setPaletteColor(colors.lime,   0x00FF00)
        term.setPaletteColor(colors.gray,   0x555555)
        term.setPaletteColor(colors.cyan,   0x00FFFF)
        term.setPaletteColor(colors.orange, 0xFF8800)
        term.setBackgroundColor(colors.black)
        term.setTextColor(colors.white)
        term.clear()
        return

    elseif not SESSION.logged_in then
        if key == keys.c then
            screen_login()
        elseif key == keys.i then
            screen_register()
        end

    else
        if key == keys.r then
            play_round("R")
        elseif key == keys.n then
            play_round("N")
        elseif key == keys.v then
            play_round("V")
        end
    end
end
