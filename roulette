local function screen_register()
    cls()
    hline(1, " ", colors.yellow, colors.orange)
    center(1, " CGCasino - Inscription ", colors.black, colors.orange)

    at(2, 4,  "Nom de compte  : ", colors.lightGray, colors.black)
